# Deploy (PL-017)
DEPLOY_HOST=example.com
DEPLOY_PORT=22
DEPLOY_USER=deploy
DEPLOY_PATH=/var/sites/planka

# Optional post-deploy command (executed on remote host)
# DEPLOY_POST_COMMAND="sudo systemctl reload nginx"

# Optional local daemon Telegram alerts (degradation/recovery)
# DAEMON_TG_BOT_TOKEN=123456:telegram_bot_token
# DAEMON_TG_CHAT_ID=123456789
# DAEMON_TG_REMINDER_SEC=1800

# GitHub App auth-service (APP-03)
# Required for scripts/codex/gh_app_auth_service.js and /token endpoint:
# GH_APP_ID=1234567
# GH_APP_INSTALLATION_ID=12345678
# GH_APP_PRIVATE_KEY_PATH=/absolute/path/to/github-app.private-key.pem
# GH_APP_INTERNAL_SECRET=change_me
#
# Optional runtime tuning:
# GH_APP_BIND=127.0.0.1
# GH_APP_PORT=8787
# GH_APP_TOKEN_SKEW_SEC=300
# GH_APP_API_BASE_URL=https://api.github.com
# GH_APP_HTTP_TIMEOUT_MS=10000
# GH_APP_PM2_APP_NAME=planka-gh-app-auth
# GH_APP_PM2_RESTART_TIMEOUT_SEC=20
#
# Daemon/watchdog auth-client tuning (APP-04):
# DAEMON_GH_AUTH_TIMEOUT_SEC=8
# Optional custom token endpoint (defaults to http://${GH_APP_BIND}:${GH_APP_PORT}/token):
# DAEMON_GH_AUTH_TOKEN_URL=http://127.0.0.1:8787/token
# Feature flag: allow daemon/watchdog to use PAT fallback when auth endpoint is unavailable.
# Accepted truthy values: 1, true, yes, on
# DAEMON_GH_TOKEN_FALLBACK_ENABLED=0
# Optional alias:
# CODEX_GH_TOKEN_FALLBACK_ENABLED=0

# Optional dedicated GitHub token for daemon/watchdog actions
# (Issue comments, PR edit/create, Project status updates).
# Используется только как аварийный fallback (если включен в runtime отдельно).
# При штатной работе daemon/watchdog берут GH_TOKEN из локального auth endpoint.
# Если fallback включен, comments/PR activity будут от владельца этого PAT.
# Typical use:
# - optional emergency fallback
# How to generate (recommended from separate bot account):
# GitHub -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
# Required scopes for current flow: repo, read:project, project
# DAEMON_GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Optional fallback name (same meaning):
# CODEX_GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional git identity for agent commits (scripts/codex/dev_commit_push.sh)
# CODEX_GIT_AUTHOR_NAME="PLANKA Codex Agent"
# CODEX_GIT_AUTHOR_EMAIL="codex-agent@users.noreply.github.com"
# CODEX_GIT_COMMITTER_NAME="PLANKA Codex Agent"
# CODEX_GIT_COMMITTER_EMAIL="codex-agent@users.noreply.github.com"
