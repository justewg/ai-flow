# Deploy (PL-017)
DEPLOY_HOST=example.com
DEPLOY_PORT=22
DEPLOY_USER=deploy
DEPLOY_PATH=/var/sites/planka

# Optional post-deploy command (executed on remote host)
# DEPLOY_POST_COMMAND="sudo systemctl reload nginx"

# Optional local daemon Telegram alerts (degradation/recovery)
# DAEMON_TG_BOT_TOKEN=123456:telegram_bot_token
# DAEMON_TG_CHAT_ID=123456789
# DAEMON_TG_REMINDER_SEC=1800

# Optional dedicated GitHub token for daemon/watchdog actions
# (Issue comments, PR edit/create, Project status updates).
# If set, daemon comments/PR activity will be authored by token owner.
# DAEMON_GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Optional fallback name (same meaning):
# CODEX_GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional git identity for agent commits (scripts/codex/dev_commit_push.sh)
# CODEX_GIT_AUTHOR_NAME="PLANKA Codex Agent"
# CODEX_GIT_AUTHOR_EMAIL="codex-agent@users.noreply.github.com"
# CODEX_GIT_COMMITTER_NAME="PLANKA Codex Agent"
# CODEX_GIT_COMMITTER_EMAIL="codex-agent@users.noreply.github.com"
