<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#11161D">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <Button
        android:id="@+id/diagnosticsToggleButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:alpha="0.88"
        android:backgroundTint="#C6252B34"
        android:minHeight="0dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="@string/diagnostics_toggle_show"
        android:textAllCaps="false"
        android:textColor="#E8EDF2"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/diagnosticsPanel"
        android:layout_width="320dp"
        android:layout_height="220dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="10dp"
        android:background="#D9161D26"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/diagnosticsTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/diagnostics_title"
                android:textColor="#F2F5F8"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/diagnosticsExportButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/diagnostics_export"
                android:textAllCaps="false"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/diagnosticsMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:maxLines="3"
            android:textColor="#A9B6C3"
            android:textSize="10sp" />

        <ScrollView
            android:id="@+id/diagnosticsScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:background="#A010151C"
            android:fillViewport="true"
            android:padding="8dp">

            <TextView
                android:id="@+id/diagnosticsLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E8EDF2"
                android:textIsSelectable="true"
                android:textSize="10sp"
                android:typeface="monospace" />
        </ScrollView>
    </LinearLayout>

</FrameLayout>
